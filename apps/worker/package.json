{
  "name": "paper-agent-worker",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "smoke": "node scripts/smoke-test.mjs",
    "typecheck": "tsc --noEmit",
    "dev:staging": "wrangler dev --config wrangler.staging.toml",
    "deploy:staging": "wrangler deploy --config wrangler.staging.toml"
  },
  "dependencies": {
    "@paper-agent/shared": "*",
    "wrangler": "^4.15.2"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "@cloudflare/workers-types": "^4.20250510.0"
  }
}
