{
  "name": "paper-agent-dashboard",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "deploy": "npm run build && wrangler pages deploy dist --project-name paper-agent-dashboard",
    "typecheck": "tsc --noEmit",
    "build:staging": "tsc -b && vite build --mode staging",
    "deploy:staging": "npm run build:staging && wrangler pages deploy dist --project-name paper-agent-dashboard-staging"
  },
  "dependencies": {
    "@paper-agent/shared": "*",
    "@vitejs/plugin-react": "^5.0.0",
    "vite": "^6.3.5",
    "typescript": "^5.8.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "lucide-react": "^0.511.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "wrangler": "^4.15.2"
  }
}
