{
  "name": "paper-agent-project",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace apps/web",
    "dev:worker": "npm run dev --workspace apps/worker",
    "dev:mcp": "npm run dev --workspace apps/mcp",
    "build": "npm run build --workspaces",
    "build:web": "npm run build --workspace apps/web",
    "deploy:web": "npm run deploy --workspace apps/web",
    "deploy:worker": "npm run deploy --workspace apps/worker",
    "deploy:mcp": "npm run deploy --workspace apps/mcp",
    "benchmark:evaluate-proposed": "node benchmark/scripts/evaluate-proposed-agent.mjs",
    "benchmark:compare-baselines": "node benchmark/scripts/compare-baselines.mjs",
    "benchmark:audit-gold": "node benchmark/scripts/audit-gold-labels.mjs",
    "benchmark:refine-gold": "node benchmark/scripts/refine-gold-candidates.mjs",
    "benchmark:run-proposed": "node benchmark/scripts/run-proposed-agent.mjs",
    "benchmark:score-gold": "node benchmark/scripts/score-gold-candidates.mjs",
    "benchmark:verify-gold": "node benchmark/scripts/verify-gold-crossref.mjs",
    "e2e:reports": "npm run e2e --workspace apps/mcp",
    "smoke:worker": "npm run smoke --workspace apps/worker",
    "smoke:mcp": "npm run smoke --workspace apps/mcp",
    "typecheck": "npm run typecheck --workspaces",
    "validate:agent-rules": "node scripts/validate-agent-rules.mjs",
    "build:web:staging": "npm run build:staging --workspace apps/web",
    "deploy:web:staging": "npm run deploy:staging --workspace apps/web",
    "deploy:worker:staging": "npm run deploy:staging --workspace apps/worker",
    "deploy:mcp:staging": "npm run deploy:staging --workspace apps/mcp",
    "smoke:worker:staging": "WORKER_URL=${STAGING_WORKER_URL:-https://paper-agent-project-staging.shch3653.workers.dev} npm run smoke:worker",
    "smoke:mcp:staging": "MCP_URL=${STAGING_MCP_URL:-https://paper-agent-mcp-staging.shch3653.workers.dev/mcp} npm run smoke:mcp",
    "staging:check": "npm run typecheck && npm run build:web:staging && npm run smoke:worker:staging && npm run smoke:mcp:staging",
    "dev:worker:local": "npm run dev --workspace apps/worker -- --port 8787",
    "smoke:worker:local": "WORKER_URL=http://localhost:8787 REQUIRE_READY=false npm run smoke:worker",
    "benchmark:auto-review-baselines": "node benchmark/scripts/auto-review-baselines.mjs"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
